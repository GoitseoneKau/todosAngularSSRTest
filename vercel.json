{
    "version": 2,
    "public": true,
    "name": "DailyTodoApp",
    "installCommand": "npm install && npm run build",
    "devCommand":"npm run ssr",
    "rewrites":[{
      "source":"/(.*)",
      "destination":"/api"
    }],
    "outputDirectory": "dist",
    "functions": {
      "api/index.js": {
        "includeFiles":"dist/todo-app/server/**"
      }
    }
  }